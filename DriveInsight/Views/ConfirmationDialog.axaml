<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DriveInsight.Views.ConfirmationDialog"
        Width="440"
        Height="320"
        CanResize="False"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

    <Window.Styles>
        <Style Selector="Button.DialogSecondaryButton">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppSoftBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="Button.DialogSecondaryButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
        </Style>

        <Style Selector="Button.DialogSecondaryButton:pressed">
            <Setter Property="Background" Value="{DynamicResource AppControlPressedBrush}" />
        </Style>

        <Style Selector="Button.DialogSecondaryButton /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppSoftBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
        </Style>

        <Style Selector="Button.DialogSecondaryButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppSoftBorderBrush}" />
        </Style>

        <Style Selector="Button.DialogSecondaryButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppControlPressedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppSoftBorderBrush}" />
        </Style>
    </Window.Styles>

    <Grid Background="{DynamicResource AppDialogOverlayBrush}">
        <Border Width="460"
                MaxWidth="460"
                Padding="22"
                Background="{DynamicResource AppDialogBackgroundBrush}"
                BorderBrush="{DynamicResource AppDialogBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                BoxShadow="0 18 44 0 #55000000"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16">
                <TextBlock Name="TitleText"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AppPrimaryTextBrush}"
                           TextWrapping="Wrap" />

                <TextBlock Name="MessageText"
                           FontSize="13"
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           TextWrapping="Wrap"
                           LineHeight="20" />

                <Border Name="WarningBox"
                        Background="{DynamicResource AppWarningBackgroundBrush}"
                        BorderBrush="#D1791A"
                        BorderThickness="3,0,0,0"
                        CornerRadius="8"
                        Padding="12">
                    <TextBlock Text="This action removes files from disk and cannot be undone from DriveInsight."
                               FontSize="12"
                               Foreground="{DynamicResource AppWarningTextBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">
                    <Button Name="CancelButton"
                            Classes="DialogSecondaryButton"
                            MinWidth="92"
                            Padding="14,7"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />
                    <Button Name="ConfirmButton"
                            MinWidth="92"
                            Padding="14,7"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Background="#D93636"
                            Foreground="#FFFFFF" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
