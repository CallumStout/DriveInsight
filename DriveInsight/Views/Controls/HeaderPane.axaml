<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DriveInsight.Views.Controls.HeaderPane"
             x:Name="Root">

    <UserControl.Styles>
        <Style Selector="Border.HeaderPaneRoot">
            <Setter Property="Background" Value="#F7F9FD" />
            <Setter Property="BorderBrush" Value="#E5EBF5" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style Selector="TextBlock.HeaderPaneTitle">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1A2436" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.HeaderIconButton">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#EEF2F7" />
            <Setter Property="Foreground" Value="#7A869B" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="Button.HeaderIconButton:pointerover">
            <Setter Property="Background" Value="#E3EAF3" />
        </Style>

        <Style Selector="Button.HeaderIconButton:pressed">
            <Setter Property="Background" Value="#D7E0EC" />
        </Style>

        <Style Selector="Button.HeaderIconButton:disabled">
            <Setter Property="Opacity" Value="0.65" />
        </Style>

        <Style Selector="Button.HeaderUpdateButton">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="Button.HeaderUpdateButton:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Button.HeaderUpdateButton:pressed">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Button.HeaderUpdateButton:disabled">
            <Setter Property="Opacity" Value="0.65" />
        </Style>
    </UserControl.Styles>

    <Border Classes="HeaderPaneRoot">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto"
              ColumnSpacing="20"
              VerticalAlignment="Center">
            <TextBlock Classes="HeaderPaneTitle"
                       Text="{Binding Title, ElementName=Root}" />

            <ContentControl Grid.Column="1"
                            Content="{Binding CenterContent, ElementName=Root}"
                            VerticalAlignment="Center" />

            <ContentControl Grid.Column="2"
                            Content="{Binding RightContent, ElementName=Root}"
                            VerticalAlignment="Center" />

            <TextBlock Grid.Column="3"
                       Text="{Binding UpdateStatus, ElementName=Root}"
                       IsVisible="{Binding ShowUpdateStatus, ElementName=Root}"
                       Foreground="#607089"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="260"
                       VerticalAlignment="Center" />

            <Button Grid.Column="4"
                    Classes="HeaderUpdateButton"
                    IsVisible="{Binding ShowUpdateButton, ElementName=Root}"
                    ToolTip.Tip="{Binding UpdateToolTip, ElementName=Root}"
                    Command="{Binding UpdateCommand, ElementName=Root}">
                <Grid Width="20"
                      Height="20">
                    <Path Data="M10,2 L10,13 M5,8 L10,13 L15,8"
                          Stroke="#31D07C"
                          StrokeThickness="2"
                          StrokeLineCap="Round"
                          StrokeJoin="Round" />
                    <Path Data="M4,17 L16,17"
                          Stroke="#31D07C"
                          StrokeThickness="2"
                          StrokeLineCap="Round" />
                </Grid>
            </Button>

            <Button Grid.Column="5"
                    Classes="HeaderIconButton"
                    IsVisible="{Binding ShowExportButton, ElementName=Root}"
                    ToolTip.Tip="{Binding ExportToolTip, ElementName=Root}"
                    Command="{Binding ExportCommand, ElementName=Root}">
                <Grid Width="18"
                      Height="18">
                    <Path Data="M4,3 H14 L17,6 V15 H4 Z M14,3 V6 H17"
                          Stroke="#7A869B"
                          StrokeThickness="1.7"
                          StrokeLineCap="Round"
                          StrokeJoin="Round" />
                    <Path Data="M7,9 H14 M7,12 H14"
                          Stroke="#7A869B"
                          StrokeThickness="1.7"
                          StrokeLineCap="Round" />
                </Grid>
            </Button>

            <Button Grid.Column="6"
                    Classes="HeaderIconButton"
                    IsVisible="{Binding ShowRefreshButton, ElementName=Root}"
                    ToolTip.Tip="{Binding RefreshToolTip, ElementName=Root}"
                    Command="{Binding RefreshCommand, ElementName=Root}">
                <TextBlock Text="↻"
                           FontSize="15"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
        </Grid>
    </Border>
</UserControl>
