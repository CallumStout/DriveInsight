<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:DriveInsight.Controls"
             xmlns:paneControls="using:DriveInsight.Views.Controls"
             xmlns:viewModels="using:DriveInsight.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="760"
             x:Class="DriveInsight.Views.DrivesPaneView">

    <UserControl.Styles>
        <Style Selector="Button#ScanDriveButton">
            <Setter Property="Background" Value="#1E63FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="Button#ScanDriveButton:pointerover">
            <Setter Property="Background" Value="#4E8DFF" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button#ScanDriveButton /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1E63FF" />
            <Setter Property="BorderBrush" Value="#1E63FF" />
        </Style>
        <Style Selector="Button#ScanDriveButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#4E8DFF" />
            <Setter Property="BorderBrush" Value="#4E8DFF" />
        </Style>
        <Style Selector="Button#ScanDriveButton:pressed">
            <Setter Property="Background" Value="#1548BD" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button#ScanDriveButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1548BD" />
            <Setter Property="BorderBrush" Value="#1548BD" />
        </Style>
        <Style Selector="Button#ScanDriveButton:disabled">
            <Setter Property="Background" Value="#AFC4F8" />
            <Setter Property="Foreground" Value="#EEF3FF" />
        </Style>

        <Style Selector="TreeDataGrid#FoldersGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ListBox#DriveTabs">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="ListBox#DriveTabs > ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,16,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#6E7C94" />
        </Style>
        <Style Selector="ListBox#DriveTabs > ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Padding" Value="12,4,12,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
        </Style>
        <Style Selector="ListBox#DriveTabs > ListBoxItem:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox#DriveTabs > ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="ListBox#DriveTabs > ListBoxItem:selected">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#1E63FF" />
        </Style>
        <Style Selector="ListBox#DriveTabs > ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="#1E63FF" />
        </Style>
        <Style Selector="ListBox#DriveTabs > ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox#DriveTabs > ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="#1E63FF" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*"
          RowSpacing="0">
        <paneControls:HeaderPane Grid.Row="0"
                                 Title="Disk Manager"
                                 ShowRefreshButton="True"
                                 RefreshToolTip="Refresh"
                                 RefreshCommand="{Binding RefreshAllCommand}">
            <paneControls:HeaderPane.CenterContent>
                <ListBox x:Name="DriveTabs"
                         ItemsSource="{Binding Drives}"
                         SelectedItem="{Binding SelectedDrive}"
                         Padding="0,4,0,0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name, StringFormat=Drive {0}}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </paneControls:HeaderPane.CenterContent>
            <paneControls:HeaderPane.RightContent>
                <StackPanel Orientation="Horizontal"
                            Spacing="12"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Status}"
                               Foreground="#69758A"
                               VerticalAlignment="Center" />
                    <Button x:Name="ScanDriveButton"
                            Content="Run Scan"
                            Command="{Binding ScanSelectedDriveCommand}" />
                </StackPanel>
            </paneControls:HeaderPane.RightContent>
        </paneControls:HeaderPane>

        <Grid Grid.Row="1"
              Margin="16,14,16,0"
              RowDefinitions="Auto,*"
              RowSpacing="14">
            <Border Grid.Row="0"
                    Background="#F7F9FC"
                    CornerRadius="14"
                    Padding="18">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="24">
                    <Grid Width="170"
                          Height="170">
                        <controls:CircularProgress Width="170"
                                                   Height="170"
                                                   Value="{Binding UsedPercentage}"
                                                   Maximum="100"
                                                   StrokeThickness="15"
                                                   StartAngle="-90"
                                                   ProgressBrush="#1E63FF"
                                                   TrackBrush="#DEE5F0" />
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                            <TextBlock Text="{Binding UsedPercentageText}"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="USED"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#7B879A"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="1"
                          ColumnDefinitions="*,*,*"
                          ColumnSpacing="22"
                          VerticalAlignment="Center">
                        <StackPanel Spacing="4">
                            <TextBlock Text="TOTAL CAPACITY"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#7B879A" />
                            <TextBlock Text="{Binding TotalCapacityText}"
                                       FontSize="30"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Spacing="4">
                            <TextBlock Text="USED SPACE"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#1E63FF" />
                            <TextBlock Text="{Binding UsedSpaceText}"
                                       FontSize="24"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Spacing="4">
                            <TextBlock Text="AVAILABLE SPACE"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#7B879A" />
                            <TextBlock Text="{Binding AvailableSpaceText}"
                                       FontSize="24"
                                       FontWeight="Bold" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <TreeDataGrid Grid.Row="1"
                          x:Name="FoldersGrid"
                          Margin="8,0,30,0"
                          Source="{Binding FolderRowsSource}" />
        </Grid>
    </Grid>
</UserControl>
