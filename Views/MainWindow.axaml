<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="DriveInsight.Views.MainWindow"
        Title="DriveInsight">

	<Grid ColumnDefinitions="300,*" RowDefinitions="Auto,*">
		<StackPanel Grid.Column="0" Margin="12" Spacing="8">
			<TextBlock Text="Drives" FontSize="18" FontWeight="Bold"/>
			<ComboBox ItemsSource="{Binding Drives}"
					  SelectedItem="{Binding SelectedDrive}">
				<ComboBox.ItemTemplate>
					<DataTemplate>
						<TextBlock Text="{Binding Name}"/>
					</DataTemplate>
				</ComboBox.ItemTemplate>
			</ComboBox>
			<Button Content="Scan Selected Drive"
					Command="{Binding ScanSelectedDriveCommand}"/>
			<TextBlock Text="{Binding Status}"/>
		</StackPanel>

		<DataGrid Grid.Column="1" Grid.Row="1" Margin="12"
				  ItemsSource="{Binding TopFolders}"
				  AutoGenerateColumns="False">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Folder" Binding="{Binding Name}" Width="2*"/>
				<DataGridTextColumn Header="Path" Binding="{Binding FullPath}" Width="4*"/>
				<DataGridTextColumn Header="Size (GB)" Binding="{Binding SizeGb}" Width="2*"/>
			</DataGrid.Columns>
		</DataGrid>
	</Grid>
</Window>
